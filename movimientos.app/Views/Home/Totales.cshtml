        <div class="row mb-4 text-center">

            <div class="col-6">
                <label class="form-label fw-semibold">Mes</label>
                <div id="mesControl" class="swipe-box">ENERO</div>
            </div>

            <div class="col-6">
                <label class="form-label fw-semibold">Año</label>
                <div id="anioControl" class="swipe-box">2026</div>
            </div>
        </div>

        <!-- Totales -->
        <div class="row g-3">

            <div class="col-md-4">
                <div class="card border border-success h-100 hover-shadow">
                    <div class="card-body">
                        <h6 class="text-success"><i class="fas fa-arrow-up me-2"></i>Créditos Totales</h6>
                        <h2 id="totalIngresos">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border border-danger h-100 hover-shadow">
                    <div class="card-body">
                        <h6 class="text-danger d-flex justify-content-between">
                            <span><i class="fas fa-arrow-down me-2"></i>Débitos Totales</span>
                            <a href="/Home/VerTodosDebitos" class="small">Ver detalle</a>
                        </h6>
                        <h2 id="totalEgresos">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border border-secondary h-100 hover-shadow">
                    <div class="card-body bg-light rounded-bottom">
                        <h6><i class="fas fa-wallet me-2"></i>Saldo Actual</h6>
                        <h2 id="saldo" class="fw-bold">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border border-success h-100 hover-shadow">
                    <div class="card-body">
                        <h6 class="text-success"><i class="fas fa-cloud me-2"></i>Créditos Virtuales</h6>
                        <h2 id="totalIngresosVirtuales">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border border-warning h-100 hover-shadow">
                    <div class="card-body">
                        <h6 class="text-warning d-flex justify-content-between">
                            <span><i class="fas fa-cloud-download-alt me-2"></i>Débitos Virtuales</span>
