        <div class="row mb-4 text-center">

            <div class="col-6">
                <label class="form-label fw-semibold">Mes</label>
                <div id="mesControl" class="swipe-box">ENERO</div>
            </div>

            <div class="col-6">
                <label class="form-label fw-semibold">Año</label>
                <div id="anioControl" class="swipe-box">2026</div>
            </div>
        </div>

        <!-- Main Wallet Balance (Centered, Full Width) -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card text-white text-center py-4" style="background: linear-gradient(135deg, #1f2937 0%, #111827 100%) !important; border-radius: 28px !important;">
                    <div class="card-body">
                        <p class="text-white-50 mb-2 text-uppercase fw-bold" style="letter-spacing: 1px;">Saldo Total</p>
                        <h1 id="saldo" class="display-4 fw-bolder mb-0 text-white">$0.00</h1>
                    </div>
                </div>
            </div>
        </div>

        <!-- Totales y Gráficos -->
        <div class="row g-4">
            <!-- Tarjetas de Métricas -->
            <div class="col-lg-8">

                <!-- Income / Expense Split -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="sp-icon-circle sp-icon-green me-3">
                                    <i class="fas fa-arrow-up"></i>
                                </div>
                                <div>
                                    <p class="text-muted mb-0 fw-semibold">Ingresos Totales</p>
                                    <h3 id="totalIngresos" class="text-success mb-0 fw-bolder">$0.00</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <div class="sp-icon-circle sp-icon-red me-3">
                                        <i class="fas fa-arrow-down"></i>
                                    </div>
                                    <div>
                                        <p class="text-muted mb-0 fw-semibold">Gastos Totales</p>
                                        <h3 id="totalEgresos" class="text-danger mb-0 fw-bolder">$0.00</h3>
                                    </div>
                                </div>
                                <a href="/Home/VerTodosDebitos" class="text-muted"><i class="fas fa-chevron-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Virtual Balances -->
                <h6 class="mb-3 text-muted fw-bold ps-2">Virtuales</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card h-100 bg-light shadow-none border">
                            <div class="card-body text-center p-3">
                                <p class="text-muted mb-1 small fw-bold">Saldo Virtual</p>
                                <h4 id="saldoActualVirtual" class="fw-bolder text-dark mb-0">$0.00</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 bg-light shadow-none border">
                            <div class="card-body text-center p-3">
                                <p class="text-success mb-1 small fw-bold">Créditos Virtuales</p>
                                <h5 id="totalIngresosVirtuales" class="fw-bold mb-0">$0.00</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 bg-light shadow-none border">
                            <div class="card-body text-center p-3 position-relative">
                                <a href="/Home/MovimientosVirtuales" class="position-absolute top-0 end-0 p-2 text-muted"><i class="fas fa-external-link-alt"></i></a>
                                <p class="text-danger mb-1 small fw-bold">Débitos Virtuales</p>
                                <h5 id="totalEgresosVirtuales" class="fw-bold mb-0">$0.00</h5>
                            </div>
                        </div>
                    </div>
                </div>

                </div>
            </div>

            <!-- Gráfico Resumen -->
            <div class="col-lg-4">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6 class="text-muted mb-4"><i class="fas fa-chart-pie me-2"></i>Distribución de Flujo Mensual</h6>
                        <div style="position: relative; height:250px; width:100%">
                            <canvas id="financeChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <script src="~/js/swipeDiv.js"></script>
    <script>
        let financeChart;

        function updateChart(ingresos, egresos) {
            const ctx = document.getElementById('financeChart').getContext('2d');
            if (financeChart) { financeChart.destroy(); }
            financeChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Créditos', 'Débitos'],
                    datasets: [{
                        data: [ingresos, egresos],
                        backgroundColor: ['#00b74a', '#f93154'],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    },
                    cutout: '70%'
                }
            });
        }

        // Función para obtener los totales según el mes seleccionado
        function obtenerTotales(mes, anio) {
            $.get(`/api/movimientos/totales?mes=${mes}&anio=${anio}`, function (data) {
                // Actualizar los valores de los totales
                $('#totalIngresos').text('$' + data.totalIngresos);
                $('#totalEgresos').text('$' + data.totalEgresos);
                $('#saldo').text('$' + data.saldo);
                $('#totalEgresosVirtuales').text('$' + data.totalEgresoVirtual);
                $('#saldoActualVirtual').text('$' + data.saldoParcial);
                $('#totalIngresosVirtuales').text('$' + data.totalIngresoVirtual);
                
                // Actualizar Gráfico
                updateChart(data.totalIngresos, data.totalEgresos);
            }).fail(function () {
                alert('Ocurrió un error al obtener los totales.');
            });
        }
        //function activarSwipe(elemento, onUp, onDown) {
        //    let startY = 0;

        //    elemento.addEventListener("touchstart", e => {
        //        startY = e.touches[0].clientY;
        //    });

        //    elemento.addEventListener("touchend", e => {
        //        let endY = e.changedTouches[0].clientY;
        //        let diff = startY - endY;

        //        if (Math.abs(diff) < 30) return; // umbral

        //        if (diff > 0) onUp();   // swipe arriba
        //        else onDown();          // swipe abajo
        //    });
        //}
        

        activarSwipe(mesBox,
            () => { // ↑
                mesIndex = (mesIndex + 1) % 12;
                mesBox.textContent = meses[mesIndex];
                obtenerTotales(mesIndex + 1, anioActual);
            },
            () => { // ↓
                mesIndex = (mesIndex - 1 + 12) % 12;
                mesBox.textContent = meses[mesIndex];
                obtenerTotales(mesIndex + 1, anioActual);
            }
        );

        activarSwipe(anioBox,
            () => { // ↑
                anioActual++;
                anioBox.textContent = anioActual;
                obtenerTotales(mesIndex + 1, anioActual);
            },
            () => { // ↓
                anioActual--;
                anioBox.textContent = anioActual;
                obtenerTotales(mesIndex + 1, anioActual);
            }
        );
        obtenerTotales(mesIndex + 1, anioActual);
    </script>
