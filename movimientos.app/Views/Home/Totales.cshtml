                        </h6>
                        <h2 id="totalEgresosVirtuales">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border border-info h-100 hover-shadow">
                    <div class="card-body bg-light rounded-bottom">
                        <h6 class="text-info"><i class="fas fa-cloud-meatball me-2"></i>Saldo Virtual</h6>
                        <h2 id="saldoActualVirtual" class="fw-bold">0</h2>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <script src="~/js/swipeDiv.js"></script>
    <script>
        // Función para obtener los totales según el mes seleccionado
        function obtenerTotales(mes, anio) {
            $.get(`/api/movimientos/totales?mes=${mes}&anio=${anio}`, function (data) {
                // Actualizar los valores de los totales
                $('#totalIngresos').text(data.totalIngresos);
                $('#totalEgresos').text(data.totalEgresos);
                $('#saldo').text(data.saldo);
                $('#totalEgresosVirtuales').text(data.totalEgresoVirtual);
                $('#saldoActualVirtual').text(data.saldoParcial);
                $('#totalIngresosVirtuales').text(data.totalIngresoVirtual);
            }).fail(function () {
                alert('Ocurrió un error al obtener los totales.');
            });
        }
        //function activarSwipe(elemento, onUp, onDown) {
        //    let startY = 0;

        //    elemento.addEventListener("touchstart", e => {
        //        startY = e.touches[0].clientY;
        //    });

        //    elemento.addEventListener("touchend", e => {
        //        let endY = e.changedTouches[0].clientY;
        //        let diff = startY - endY;

        //        if (Math.abs(diff) < 30) return; // umbral

        //        if (diff > 0) onUp();   // swipe arriba
        //        else onDown();          // swipe abajo
        //    });
        //}
        

        activarSwipe(mesBox,
            () => { // ↑
                mesIndex = (mesIndex + 1) % 12;
                mesBox.textContent = meses[mesIndex];
                obtenerTotales(mesIndex + 1, anioActual);
            },
            () => { // ↓
                mesIndex = (mesIndex - 1 + 12) % 12;
                mesBox.textContent = meses[mesIndex];
                obtenerTotales(mesIndex + 1, anioActual);
            }
        );

        activarSwipe(anioBox,
            () => { // ↑
                anioActual++;
                anioBox.textContent = anioActual;
                obtenerTotales(mesIndex + 1, anioActual);
            },
            () => { // ↓
                anioActual--;
                anioBox.textContent = anioActual;
                obtenerTotales(mesIndex + 1, anioActual);
            }
        );
        obtenerTotales(mesIndex + 1, anioActual);
    </script>
