    <div class="container mt-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="mb-1">Gestión de Categorías</h3>
                <small class="text-muted">
                    Administra tus categorías y subcategorías de movimientos
                </small>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-mdb-ripple-init id="btnAtras">
                    <i class="fas fa-arrow-left me-1"></i> Volver
                </button>

                <button class="btn btn-primary btn-sm" data-mdb-ripple-init
                        id="addCategoryBtn"
                        data-mdb-ripple-init data-mdb-modal-init
                        data-mdb-target="#categoriaModal">
                    <i class="fas fa-plus me-1"></i> Agregar Categoría
                </button>
            </div>
        </div>

        <!-- Lista de categorías -->
        <div class="row g-3" id="categoriaList">
            <!-- Categorías renderizadas por JS -->
        </div>

    </div>
    <div class="modal fade" id="categoriaModal" tabindex="-1" aria-labelledby="categoriaModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="categoriaModalLabel">Agregar Categoría</h5>
                    <button type="button" class="btn-close" data-mdb-ripple-init data-mdb-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="categoriaForm">
                        <input type="hidden" id="categoriaId" />
                        <div class="form-outline mb-4">
                            <input type="text" class="form-control" id="nombre" required />
                            <label for="nombre" class="form-label">Nombre de Categoría</label>
                        </div>
                        <button type="submit" class="btn btn-success" data-mdb-ripple-init id="submitBtn">Agregar Categoría</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmDeleteModalLabel">Confirmar Eliminación</h5>
                    <button type="button" class="btn-close" data-mdb-ripple-init data-mdb-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Estás seguro de que deseas eliminar esta categoría?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-mdb-ripple-init data-mdb-dismiss="modal" data-mdb-ripple-init>Cancelar</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn" data-mdb-ripple-init>Eliminar</button>
                </div>
            </div>
        </div>
    </div>
    <script>
        $(document).ready(function () {
            // Obtener todas las categorías
            function getCategorias() {
                $.get("/api/categoria", function (data) {
                    $('#categoriaList').empty(); // Limpiar lista antes de renderizar
                    data.forEach(function (categoria) {
                        //$('#categoriaList').append(`
                        //                <div class="col-md-4 mb-4">
                        //                    <div class="card" style="cursor: pointer;">
                        //                            <div class="card-header"><h5 class="card-title" data-id="${categoria.id}" data-name="${categoria.nombre}" >${categoria.nombre}</h5></div>
                        //                        <div class="card-body">
                        //                            <div class="d-flex justify-content-between">
                        //                                <button class="btn btn-warning btn-sm editBtn" data-id="${categoria.id}" data-mdb-ripple-init data-mdb-modal-init data-mdb-target="#categoriaModal">Editar</button>
                        //                                <button class="btn btn-danger btn-sm deleteBtn" data-id="${categoria.id}" data-mdb-ripple-init data-mdb-modal-init data-mdb-target="#confirmDeleteModal">Eliminar</button>
                        //                            </div>
                        //                        </div>
                        //                        <div class="card-footer"></div>
                        //                    </div>
                        //                </div>
                        //            `);
                        $('#categoriaList').append(`
                        <div class="col-md-3 col-sm-6 mb-4">
                            <div class="card h-100 text-center p-3 position-relative" style="cursor:pointer; border-radius: 28px;">
                                <!-- Acciones Flotantes Ocultas -->
                                <div class="position-absolute top-0 end-0 p-2 d-flex gap-1" style="z-index: 10;">
                                    <button class="btn btn-link btn-sm editBtn p-1 text-muted"
                                            data-id="${categoria.id}"
                                            data-name="${categoria.nombre}"
                                            data-mdb-ripple-init data-mdb-modal-init
                                            data-mdb-target="#categoriaModal"
                                            title="Editar">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <button class="btn btn-link btn-sm deleteBtn p-1 text-muted"
                                            data-id="${categoria.id}"
                                            data-mdb-ripple-init data-mdb-modal-init
                                            data-mdb-target="#confirmDeleteModal"
                                            title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                                
                                <div class="card-body ripple d-flex flex-column align-items-center justify-content-center" data-mdb-ripple-init data-mdb-ripple-color="light" data-id="${categoria.id}" data-name="${categoria.nombre}" style="border-radius: 20px;">
                                    <div class="sp-icon-circle bg-light text-primary mb-3 mx-auto" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                        <i class="fas fa-wallet"></i>
                                    </div>
                                    <h5 class="card-title fw-bold text-dark mb-1">${categoria.nombre}</h5>
                                    <small class="text-muted">Movimientos</small>
                                </div>
                            </div>
                        </div>
                    `);
                    });
                });
            }

            // Llamar a la función para cargar categorías cuando se carga la página
            getCategorias();

            // Crear o actualizar una categoría
            $('#categoriaForm').submit(function (e) {
                e.preventDefault();
                const id = $('#categoriaId').val();
                const nombre = $('#nombre').val();

                const url = id ? `/api/categoria/${id}` : '/api/categoria'; // Si tiene id, es actualizar
                const method = id ? 'PUT' : 'POST'; // Si tiene id, usar PUT

                $.ajax({
                    url: url,
                    method: method,
                    data: JSON.stringify({ nombre: nombre }),
                    contentType: 'application/json',
                    success: function () {
                        // Limpiar formulario y recargar categorías
                        $('#categoriaId').val('');
                        $('#nombre').val('');
                        $('#submitBtn').text('Agregar Categoría');
                        let catModal = mdb.Modal.getInstance(document.getElementById('categoriaModal'));
                        if (catModal) catModal.hide();
                        getCategorias();
                    }
                });
            });

            // Editar categoría
            $(document).on('click', '.editBtn', function () {
                const id = $(this).data('id');
                $('#categoriaModalLabel').text('Editar Categoría');
                $('#submitBtn').text('Guardar Cambios');
                $.ajax({
                    url: `/api/categoria/GetCategoriaId?categoria=${id}`,
                    method: 'GET',
                    success: function (data) {
                        $('#categoriaId').val(data.id);
                        $('#nombre').val(data.nombre);
                        $('#submitBtn').text('Actualizar Categoría');
                    }
                });
            });

            // Mostrar modal de confirmación para eliminar categoría
            $(document).on('click', '.deleteBtn', function () {
                const id = $(this).data('id');
                $('#confirmDeleteBtn').data('id', id); // Guardar el ID para usarlo al confirmar la eliminación
            });

            $('#addCategoryBtn').on('click', function () {
                $('#categoriaModalLabel').text('Agregar Categoría');
                $('#submitBtn').text('Agregar Categoría');
                $('#categoriaForm')[0].reset();
            });
            // Confirmar eliminación de categoría
            $('#confirmDeleteBtn').click(function () {
                const id = $(this).data('id');
                $.ajax({
                    url: `/api/categoria/${id}`,
                    method: 'DELETE',
                    success: function () {
                        let delModal = mdb.Modal.getInstance(document.getElementById('confirmDeleteModal'));
                        if (delModal) delModal.hide();
                        getCategorias();
                    }
                });
            });

            // Redirigir a la página de movimientos al hacer clic en una categoría
            $(document).on('click', '.card-body', function () {
                let categoriaId = $(this).data('id');
                let categoriaName = $(this).data('name');
                window.location.href = `/Home/Movimientos?id=${categoriaId}&catname=${categoriaName}`;
            });

            $('#btnAtras').click(function () {
                location.href = "/";
            });
        });
    </script>
</body>
</html>
