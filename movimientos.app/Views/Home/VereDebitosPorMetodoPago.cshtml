<link href="~/css/rowbotones.css" rel="stylesheet"/>
<div class="container">
    <h3>
        Debitos por metodo de pago
    </h3>
    <div class="row">
        <div class="row mb-4 text-center">
            <div class="col-6">
                <label class="form-label fw-semibold">Mes</label>
                <div id="mesControl" class="swipe-box">ENERO</div>
            </div>

            <div class="col-6">
                <label class="form-label fw-semibold">Año</label>
                <div id="anioControl" class="swipe-box">2026</div>
            </div>
        </div>
        @*<div class="col-sm-4">
            <label for="metodopago" class="form-label">Tipo</label>
            <select class="form-control" id="metodopago">
            </select>
        </div>*@
    <div class="col-sm-4">
        <label class="form-label">Tipo</label>

        <div id="metodopago" class="btn-group btn-group-wrap w-100" role="group">
            <!-- Botones -->

        </div>
        <input type="hidden" id="metodoseleccionado" />
    </div>



        <div class="col-sm-4">
            Total Movimientos Virtuales: <strong id="total"></strong>
        </div>
    </div>
    <div id="movimientosList" class="table-responsive">
    </div>
</div>
<script src="~/js/swipeDiv.js"></script>
<script>
    function getTipo(tipo) {
        switch (tipo) {
            case 0: return 'Egreso';
                break;
            case 1: return 'Ingreso';
                break;
            case 2: return 'Egreso Virtual';
                break;
        }
    }
    function changePage(direction) {
        PageNumber += direction;
        getMovimientos($('#mes').val(), $("#metodopago").val(), $("#anio").val());
    }
    
    function cargarMetodosPago() {
        $.get('/api/metodospagos', function (metodosPago) {
            const contenedor = $('#metodopago');
            contenedor.empty();

            metodosPago.forEach(metodo => {
                const boton = `
                <input type="radio" class="btn-check" name="metodopago" id="mp_${metodo.id}" onclick="setValuebutton(${metodo.id})" value="${metodo.id}">
                <label class="btn btn-outline-primary" for="mp_${metodo.id}">
                    ${metodo.metodo}
                </label>
            `;
                contenedor.append(boton);
            });
        }).fail(function (error) {
            console.error('Error al obtener los métodos de pago:', error);
        });
    }

    function getMovimientos(mesSeleccionado, tipopago, anio) {
        $.get(`/api/movimientos/egresoportipopago?mes=${mesSeleccionado}&tipopago=${tipopago}&anio=${anio}`, function (data) {
            $('#movimientosList').empty();
            let totalMonto = 0;
            if (data.length === 0) {
                $('#movimientosList').append('<p>No hay movimientos para esta categoría.</p>');
            } else {
                let table = `
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Monto</th>
                                            <th>Cantidad</th>
                                            <th>Descripción</th>
                                            <th>Fecha</th>
                                            <th>Tipo</th>
                                            <th>Categoria</th>
                                            <th>Metodo de pago</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                            `;
                data.forEach(function (movimiento) {
                    totalMonto += parseFloat(movimiento.monto);
                    table += `
                                    <tr>
                                        <td>${movimiento.monto}</td>
                                        <td>${movimiento.cantidad}</td>
                                        <td>${movimiento.descripcion}</td>
                                        <td>${movimiento.fecha.split("T")[0]}</td>
                                        <td>${getTipo(movimiento.tipo)}</td>
                                        <td>${movimiento.categoria.nombre}</td>
                                        <td>${movimiento.metodopago?.metodo || 'N/A'}</td>
                                    </tr>
                                `;
                });
                table += '</tbody></table>';
                $('#movimientosList').append(table);
            }
            $("#total").text(totalMonto.toFixed(2));
        });
    }
    cargarMetodosPago();
    //$('#metodopago').change(function () {
    //    getMovimientos(mesIndex + 1, this.value, anioActual);
    //});
    function setValuebutton(value) {
        $("#metodoseleccionado").val(value);
        getMovimientos(mesIndex + 1, value, anioActual);
    }
    activarSwipe(mesBox,
        () => { // ↑
            mesIndex = (mesIndex + 1) % 12;
            mesBox.textContent = meses[mesIndex];
            if ($("#metodoseleccionado").val() != undefined && $("#metodoseleccionado").val() != null && $("#metodoseleccionado").val() != "") {
                getMovimientos(mesIndex + 1, $('#metodoseleccionado').val(), anioActual);
            }
            
        },
        () => { // ↓
            mesIndex = (mesIndex - 1 + 12) % 12;
            mesBox.textContent = meses[mesIndex];
            if ($("#metodoseleccionado").val() != undefined && $("#metodoseleccionado").val() != null && $("#metodoseleccionado").val() != "") {
                getMovimientos(mesIndex + 1, $('#metodoseleccionado').val(), anioActual);
            }
        }
    );

    activarSwipe(anioBox,
        () => { // ↑
            anioActual++;
            anioBox.textContent = anioActual;
            if ($("#metodoseleccionado").val() != undefined && $("#metodoseleccionado").val() != null && $("#metodoseleccionado").val() != "") {
                getMovimientos(mesIndex + 1, $('#metodoseleccionado').val(), anioActual);
            }
        },
        () => { // ↓
            anioActual--;
            anioBox.textContent = anioActual;
            if ($("#metodoseleccionado").val() != undefined && $("#metodoseleccionado").val() != null && $("#metodoseleccionado").val() != "") {
                getMovimientos(mesIndex + 1, $('#metodoseleccionado').val(), anioActual);
            }
        }
    );
</script>